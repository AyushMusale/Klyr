# ============================================
# DATABASE CONFIGURATION
# ============================================
DATABASE_URL=postgresql://user:password@localhost:5432/klyr

# ============================================
# SERVER CONFIGURATION
# ============================================
SERVER_PORT=3000
NODE_ENV=development

# ============================================
# AUTHENTICATION - JWT
# ============================================
# Generate random strings using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_ACCESS_SECRET=your_random_access_secret_key_change_this_for_production
JWT_REFRESH_SECRET=your_random_refresh_secret_key_change_this_for_production
SESSION_SECRET=your_session_secret_key

# ============================================
# AUTHENTICATION - GOOGLE OAUTH
# ============================================
# Get credentials from: https://console.cloud.google.com/
# Create OAuth 2.0 credentials (Web Application)
GOOGLE_CLIENT_ID_WEBAPP=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# ============================================
# FRONTEND URL (for CORS and OAuth redirects)
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# CACHING - REDIS (Optional)
# ============================================
# Local Redis
REDIS_URL=redis://localhost:6379

# OR Upstash Redis (Serverless)
# UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# ============================================
# EMAIL SERVICE - RESEND (Optional)
# ============================================
# Get API key from: https://resend.com
RESEND_API_KEY=your_resend_api_key